rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function calendarDoc(appId, calId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/calendars/$(calId));
    }

    function isCalendarMember(appId, calId) {
      return signedIn()
        && (request.auth.uid in calendarDoc(appId, calId).data.members);
    }

    function isCalendarOwner(appId, calId) {
      return signedIn()
        && (calendarDoc(appId, calId).data.ownerId == request.auth.uid);
    }

    // --- Root scope for your app data ---
    match /artifacts/{appId}/{document=**} {

      // USERS (private per user)
      match /users/{uid} {
        allow read, write: if isSelf(uid);

        // All subcollections under the user are also private
        match /{subCollection}/{docId} {
          allow read, write: if isSelf(uid);
        }
      }

      // PUBLIC PROFILES (readable by anyone, writable by self)
      match /public_profiles/{uid} {
        allow read: if true;
        allow create, update, delete: if isSelf(uid);
      }

      // CALENDARS (new shared structure)
      match /calendars/{calId} {
        // Member can read calendar doc
        allow get, list: if signedIn() && (request.auth.uid in resource.data.members);

        // Create: owner must be the creator and must be in members
        allow create: if signedIn()
          && request.resource.data.ownerId == request.auth.uid
          && (request.auth.uid in request.resource.data.members);

        // Update: only owner (keeps sharing/roles safer)
        allow update: if isCalendarOwner(appId, calId);

        // Delete: only owner
        allow delete: if isCalendarOwner(appId, calId);

        // Subcollections (events/schedule/shifts etc.)
        match /{subCollection}/{docId} {
          // All calendar members can read/write calendar content
          allow read, write: if isCalendarMember(appId, calId);
        }
      }

      // NOTIFICATION QUEUE (client may only CREATE, no reads)
      match /notification_queue/{id} {
        allow create: if signedIn()
          && request.resource.data.data.senderId == request.auth.uid;
        allow read, update, delete: if false;
      }

      // SECRET FEATURES (basic: only signed-in; tighten later if needed)
      match /secret_groups/{id} {
        allow read, write: if signedIn();
      }
      match /secret_chats/{id} {
        allow read, write: if signedIn();
      }
      match /secret_requests/{id} {
        allow read, write: if signedIn();
      }
      match /secret_public_codes/{id} {
        allow read, write: if signedIn();
      }
    }
  }
}